rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() ? request.auth.token.role : "";
    }

    function isSuperAdmin() {
      return role() == "SUPER_ADMIN";
    }

    function isSeedAdmin() {
      return signedIn() &&
        (request.auth.token.seed_admin == true || role() == "seed_admin");
    }

    function isSuperOrSeedAdmin() {
      return isSuperAdmin() || isSeedAdmin();
    }

    function isCompanyAdmin(companyId) {
      return signedIn() &&
        role() == "COMPANY_ADMIN" &&
        request.auth.token.company_id == companyId;
    }

    function isNurseryAdmin(nurseryId) {
      return signedIn() &&
        role() == "NURSERY_ADMIN" &&
        request.auth.token.nursery_id == nurseryId;
    }

    function isTabletDevice(nurseryId, roomId, tabletId) {
      return signedIn() &&
        role() == "TABLET_DEVICE" &&
        request.auth.token.nursery_id == nurseryId &&
        request.auth.token.room_id == roomId &&
        request.auth.token.tablet_id == tabletId;
    }

    function hasStatus(data, allowed) {
      return ("status" in data) && data.status in allowed;
    }

    function activeProduct(data) {
      return hasStatus(data, ["active", "approved"]);
    }

    function activeOption(data) {
      return hasStatus(data, ["active"]);
    }

    function publishedContent(data) {
      return hasStatus(data, ["published", "active"]) &&
        (!("visible_from" in data) || data.visible_from <= request.time) &&
        (!("visible_until" in data) || data.visible_until >= request.time);
    }

    function companyScoped(data) {
      return ("company_id" in data) && isCompanyAdmin(data.company_id);
    }

    function nurseryScoped(data) {
      return ("nursery_id" in data) && isNurseryAdmin(data.nursery_id);
    }

    function tabletScoped(data) {
      return ("nursery_id" in data) &&
        ("room_id" in data) &&
        ("tablet_id" in data) &&
        isTabletDevice(data.nursery_id, data.room_id, data.tablet_id);
    }

    function guestQrTokenRead(data) {
      return ("guest_read_enabled" in data) &&
        data.guest_read_enabled == true &&
        ("status" in data) &&
        data.status in ["active", "paid", "expired", "cancelled"] &&
        ("short_code" in data);
    }

    function guestOrderTokenRead(data) {
      return ("guest_lookup_enabled" in data) &&
        data.guest_lookup_enabled == true &&
        ("order_no" in data);
    }

    function superSeedWrite(data) {
      return isSuperOrSeedAdmin() &&
        ("updated_at" in data) &&
        ("status" in data);
    }

    function betaCmsRead() {
      return true;
    }

    function betaCmsWrite(data) {
      return ("guest_write_enabled" in data) &&
        data.guest_write_enabled == true &&
        ("source" in data) &&
        data.source == "cms_beta" &&
        ("source_app" in data) &&
        data.source_app in ["admin", "company", "nursery", "tablet"] &&
        ("updated_at" in data) &&
        ("status" in data) &&
        data.status in ["draft", "pending_approval", "approved", "scheduled", "live", "paused", "rejected", "uploaded"];
    }

    function betaCompanyDocumentWrite(data) {
      return betaCmsWrite(data) &&
        ("company_id" in data) &&
        ("document_type" in data) &&
        ("document_label" in data) &&
        ("storage_path" in data) &&
        ("download_url" in data) &&
        ("file_name" in data) &&
        ("source_channel" in data) &&
        data.source_channel == "company_admin_file_upload";
    }

    function betaCompanySignupWrite(data) {
      return ("guest_write_enabled" in data) &&
        data.guest_write_enabled == true &&
        ("source" in data) &&
        data.source == "cms_beta" &&
        ("source_app" in data) &&
        data.source_app == "company" &&
        ("source_channel" in data) &&
        data.source_channel == "company_signup_request" &&
        ("updated_at" in data) &&
        ("status" in data) &&
        data.status in ["pending_review", "infiny_sent", "approved", "on_hold", "rejected"];
    }

    // Public storefront catalog. Write is limited to SUPER_ADMIN/seed_admin beta operations.
    match /products/{productId} {
      allow get, list: if activeProduct(resource.data) || companyScoped(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /product_options/{optionId} {
      allow get, list: if activeOption(resource.data) || companyScoped(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /product_detail_pages/{pageId} {
      allow get, list: if betaCmsRead() || publishedContent(resource.data) || companyScoped(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data) || betaCmsWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /company_api_integration_requests/{requestId} {
      allow get, list: if betaCmsRead() || isSuperOrSeedAdmin() || companyScoped(resource.data);
      allow create, update: if superSeedWrite(request.resource.data) || betaCmsWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /pg_gateway_settings/{settingId} {
      allow get, list: if betaCmsRead() || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data) || betaCmsWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /pg_provider_settings/{settingId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /company_pg_credentials/{credentialId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if false;
    }

    match /nursery_auto_signup_profiles/{profileId} {
      allow get, list: if betaCmsRead() || isSuperOrSeedAdmin() || nurseryScoped(resource.data);
      allow create, update: if superSeedWrite(request.resource.data) || betaCmsWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /product_reviews/{reviewId} {
      allow get, list: if publishedContent(resource.data) || companyScoped(resource.data) || isSuperOrSeedAdmin();
      allow write: if false;
    }

    match /product_questions/{questionId} {
      allow get, list: if companyScoped(resource.data) || isSuperOrSeedAdmin();
      allow write: if false;
    }

    // Published CMS/home/marketing content.
    match /brands/{brandId} {
      allow get, list: if betaCmsRead() || publishedContent(resource.data) || companyScoped(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data) || betaCmsWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /home_sections/{sectionId} {
      allow get, list: if betaCmsRead() || publishedContent(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data) || betaCmsWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /marketing_banners/{bannerId} {
      allow get, list: if betaCmsRead() || publishedContent(resource.data) || companyScoped(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data) || betaCmsWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /marketing_videos/{videoId} {
      allow get, list: if betaCmsRead() || publishedContent(resource.data) || companyScoped(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data) || betaCmsWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /exhibitions/{exhibitionId} {
      allow get, list: if publishedContent(resource.data) || companyScoped(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /exhibition_products/{entryId} {
      allow get, list: if publishedContent(resource.data) || companyScoped(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /popups/{popupId} {
      allow get, list: if publishedContent(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /tablet_home_configs/{configId} {
      allow get, list: if betaCmsRead() || publishedContent(resource.data) || nurseryScoped(resource.data) || tabletScoped(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data) || betaCmsWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /media_assets/{assetId} {
      allow get, list: if betaCmsRead() || publishedContent(resource.data) || companyScoped(resource.data) || nurseryScoped(resource.data) || isSuperOrSeedAdmin();
      allow create, update: if superSeedWrite(request.resource.data) || betaCmsWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    // Organization/facility foundation. Role/scope based read, seed/admin write only.
    match /companies/{companyId} {
      allow get, list: if isSuperOrSeedAdmin() || isCompanyAdmin(companyId);
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if false;
    }

    match /company_onboarding/{onboardingId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data);
      allow create, update: if false;
      allow delete: if false;
    }

    match /company_signup_requests/{requestId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow create: if betaCompanySignupWrite(request.resource.data) || isSuperOrSeedAdmin();
      allow update: if isSuperOrSeedAdmin();
      allow delete: if false;
    }

    match /company_documents/{documentId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data);
      allow create, update: if betaCompanyDocumentWrite(request.resource.data) || isSuperOrSeedAdmin();
      allow delete: if false;
    }

    match /a1_company_document_inbox/{inboxId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow create, update: if betaCompanyDocumentWrite(request.resource.data) || isSuperOrSeedAdmin();
      allow delete: if false;
    }

    match /gmail_delivery_queue/{queueId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow create, update: if betaCompanyDocumentWrite(request.resource.data) || isSuperOrSeedAdmin();
      allow delete: if false;
    }

    match /company_contacts/{contactId} {
      allow get, list: if publishedContent(resource.data) || isSuperOrSeedAdmin() || companyScoped(resource.data);
      allow create, update: if false;
      allow delete: if false;
    }

    match /nurseries/{nurseryId} {
      allow get, list: if isSuperOrSeedAdmin() || isNurseryAdmin(nurseryId);
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if false;
    }

    match /rooms/{roomId} {
      allow get, list: if isSuperOrSeedAdmin() || nurseryScoped(resource.data) || tabletScoped(resource.data);
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /tablets/{tabletId} {
      allow get, list: if isSuperOrSeedAdmin() || nurseryScoped(resource.data) || tabletScoped(resource.data);
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    // Tablet/customer session reads are token/scope based. Direct client writes are blocked.
    match /carts/{cartId} {
      allow get, list: if isSuperOrSeedAdmin() || tabletScoped(resource.data);
      allow write: if false;
    }

    match /cart_items/{cartItemId} {
      allow get, list: if isSuperOrSeedAdmin() || tabletScoped(resource.data);
      allow write: if false;
    }

    match /qr_payment_sessions/{sessionId} {
      allow get, list: if isSuperOrSeedAdmin() ||
        nurseryScoped(resource.data) ||
        tabletScoped(resource.data) ||
        guestQrTokenRead(resource.data);
      allow write: if false;
    }

    // Server-owned commerce ledgers. Client writes are always denied.
    match /payment_intents/{intentId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow write: if false;
    }

    match /order_drafts/{draftId} {
      allow get, list: if isSuperOrSeedAdmin() || nurseryScoped(resource.data);
      allow write: if false;
    }

    match /orders/{orderId} {
      allow get, list: if isSuperOrSeedAdmin() || nurseryScoped(resource.data) || guestOrderTokenRead(resource.data);
      allow write: if false;
    }

    match /order_items/{orderItemId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data) || nurseryScoped(resource.data) || guestOrderTokenRead(resource.data);
      allow write: if false;
    }

    match /payments/{paymentId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow write: if false;
    }

    match /payment_events/{eventId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow write: if false;
    }

    match /webhook_events/{eventId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow write: if false;
    }

    match /cancel_requests/{requestId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data) || nurseryScoped(resource.data);
      allow write: if false;
    }

    match /inventory_movements/{movementId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data);
      allow write: if false;
    }

    match /inventory_reservations/{reservationId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data) || nurseryScoped(resource.data);
      allow write: if false;
    }

    match /audit_logs/{logId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow write: if false;
    }

    match /payment_audit_logs/{logId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow write: if false;
    }

    match /refunds/{refundId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data) || nurseryScoped(resource.data);
      allow write: if false;
    }

    match /delivery_events/{eventId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data) || nurseryScoped(resource.data);
      allow write: if false;
    }

    match /pickup_events/{eventId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data) || nurseryScoped(resource.data);
      allow write: if false;
    }

    match /settlements/{settlementId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data);
      allow write: if false;
    }

    match /payouts/{payoutId} {
      allow get, list: if isSuperOrSeedAdmin() || companyScoped(resource.data);
      allow write: if false;
    }

    match /notification_logs/{logId} {
      allow get, list: if isSuperOrSeedAdmin();
      allow write: if false;
    }

    // Beta operator reference data.
    match /system_status/{statusId} {
      allow get, list: if signedIn();
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /policies/{policyId} {
      allow get, list: if signedIn() || publishedContent(resource.data);
      allow create, update: if superSeedWrite(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
