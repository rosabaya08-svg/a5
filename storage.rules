rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() ? request.auth.token.role : "";
    }

    function isSuperAdmin() {
      return role() == "SUPER_ADMIN";
    }

    function isCompanyAdmin(companyId) {
      return signedIn() &&
        role() == "COMPANY_ADMIN" &&
        request.auth.token.company_id == companyId;
    }

    function isNurseryAdmin(nurseryId) {
      return signedIn() &&
        role() == "NURSERY_ADMIN" &&
        request.auth.token.nursery_id == nurseryId;
    }

    function publicReadEnabled() {
      return true;
    }

    function betaCmsUpload() {
      return request.resource != null &&
        request.resource.size < 25 * 1024 * 1024 &&
        (
          request.resource.contentType.matches("image/.*") ||
          request.resource.contentType.matches("video/.*")
        );
    }

    // Beta CMS policy: storefront media registration is enabled for A5 closed-mall setup.
    // Payment, order, settlement, and private documents remain blocked.
    match /public/storefront/{fileName=**} {
      allow read: if publicReadEnabled();
      allow create, update: if betaCmsUpload() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /companies/{companyId}/products/{productId}/images/{fileName=**} {
      allow read: if publicReadEnabled() || isSuperAdmin() || isCompanyAdmin(companyId);
      allow create, update: if betaCmsUpload() || isSuperAdmin() || isCompanyAdmin(companyId);
      allow delete: if isSuperAdmin() || isCompanyAdmin(companyId);
    }

    match /companies/{companyId}/products/{productId}/gifs/{fileName=**} {
      allow read: if publicReadEnabled() || isSuperAdmin() || isCompanyAdmin(companyId);
      allow create, update: if betaCmsUpload() || isSuperAdmin() || isCompanyAdmin(companyId);
      allow delete: if isSuperAdmin() || isCompanyAdmin(companyId);
    }

    match /companies/{companyId}/products/{productId}/videos/{fileName=**} {
      allow read: if publicReadEnabled() || isSuperAdmin() || isCompanyAdmin(companyId);
      allow create, update: if betaCmsUpload() || isSuperAdmin() || isCompanyAdmin(companyId);
      allow delete: if isSuperAdmin() || isCompanyAdmin(companyId);
    }

    match /companies/{companyId}/onboarding/{fileName=**} {
      allow read: if isSuperAdmin() || isCompanyAdmin(companyId);
      allow write: if false;
    }

    match /companies/{companyId}/bank-documents/{fileName=**} {
      allow read: if isSuperAdmin() || isCompanyAdmin(companyId);
      allow write: if false;
    }

    match /companies/{companyId}/ad-materials/{fileName=**} {
      allow read: if publicReadEnabled() || isSuperAdmin() || isCompanyAdmin(companyId);
      allow create, update: if betaCmsUpload() || isSuperAdmin() || isCompanyAdmin(companyId);
      allow delete: if isSuperAdmin() || isCompanyAdmin(companyId);
    }

    match /nurseries/{nurseryId}/business-documents/{fileName=**} {
      allow read: if isSuperAdmin() || isNurseryAdmin(nurseryId);
      allow write: if false;
    }

    match /nurseries/{nurseryId}/rooms/{roomId}/tablet-proofs/{fileName=**} {
      allow read: if isSuperAdmin() || isNurseryAdmin(nurseryId);
      allow write: if false;
    }

    match /settlements/{period}/{companyId}/{fileName=**} {
      allow read: if isSuperAdmin() || isCompanyAdmin(companyId);
      allow write: if false;
    }

    match /payouts/{period}/{companyId}/{fileName=**} {
      allow read: if isSuperAdmin() || isCompanyAdmin(companyId);
      allow write: if false;
    }

    match /policies/{policyId}/{fileName=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /audit-exports/{yyyy}/{mm}/{fileName=**} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
